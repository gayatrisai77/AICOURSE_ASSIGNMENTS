<?xml version="1.0"?>

<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns="http://example.org/tourism#">

<owl:Class rdf:ID="Place"/>
<owl:Class rdf:ID="Food"/>

<Place rdf:ID="Hyderabad"/>
<Food rdf:ID="Biryani"/>

<Place rdf:ID="Goa"/>
<Food rdf:ID="SeaFood"/>

</rdf:RDF>
